# Portfolio Contact Form Configuration
# Copy this file to .env and fill in your values

# Gmail Configuration (Recommended: Use Gmail App Password)
# 1. Go to myaccount.google.com/apppasswords
# 2. Generate a new app password for Mail
# 3. Copy the password below (no spaces)
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# Email address that receives contact form submissions
RECIPIENT_EMAIL=lumabemarc@gmail.com

# Server port (default: 3000)
PORT=3000

# Node environment
NODE_ENV=development
